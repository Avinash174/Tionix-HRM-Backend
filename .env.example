# =============================================================================
# HRM Backend — copy to .env and uncomment ONE database block
# =============================================================================

# --- OPTION A: LOCAL MySQL (original IERPSystem on your Mac) ---
# DB_DRIVER=mysql
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=IERPSystem
# (Comment out DATABASE_URL when using MySQL)

# --- OPTION B: LOCAL PostgreSQL ---
# DB_DRIVER=postgres
# DATABASE_URL=postgresql://postgres:your_password@127.0.0.1:5432/postgres
# DB_SSL=false

# --- OPTION C: SUPABASE — local Mac (direct connection OK) ---
DB_DRIVER=postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# --- OPTION C2: SUPABASE on RENDER (use Session pooler — IPv4, NOT direct db.* URL) ---
# Supabase Dashboard → Connect → Session mode → copy URI, e.g.:
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# Direct db.YOUR_PROJECT.supabase.co fails on Render with ENETUNREACH (IPv6).

# =============================================================================
# RENDER.COM (production — set in Dashboard → Environment, NOT in .env file)
# =============================================================================
# Build command:  npm install
# Start command:   npm start
# Render sets PORT automatically — do not hardcode 5001 on Render.
#
# Required on Render:
#   DB_DRIVER=postgres
#   DATABASE_URL=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres
#   JWT_SECRET=...
#   JWT_REFRESH_SECRET=...
#
# Mobile / Postman base URL (Render gives HTTPS automatically):
#   https://YOUR-SERVICE.onrender.com
#   Login: POST https://YOUR-SERVICE.onrender.com/login
#
# Do NOT set on Render: USE_HTTPS=true, PORT=5001, MYSQL_*, localhost DATABASE_URL
#
# After code fixes: git push → Render auto-deploy (or Manual Deploy)

# =============================================================================
# Server (local only — phone on same Wi‑Fi)
# =============================================================================
PORT=5001
HOST=0.0.0.0
NODE_ENV=development

# HTTPS for mobile (https://192.168.1.5:5001) — run once: npm run cert:dev
# USE_HTTPS=true
# DEV_LAN_IP=192.168.1.5

# =============================================================================
# Auth
# =============================================================================
JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_refresh_in_production

# =============================================================================
# Geofence (fixed offices in config/officeGeofences.js)
# =============================================================================
GEFENCE_RADIUS=25
ATTENDANCE_RADIUS_METERS=25
DEFAULT_OFFICE_RADIUS_METERS=25

# =============================================================================
# Shift validation
# =============================================================================
SHIFT_VALIDATION_ENABLED=true
SHIFT_VALIDATION_STRICT=false
SHIFT_GRACE_IN_MINUTES=60
SHIFT_LATE_IN_MINUTES=120
SHIFT_EARLY_OUT_MINUTES=30
SHIFT_LATE_OUT_MINUTES=120

# =============================================================================
# Live GPS tracking
# =============================================================================
LIVE_LOCATION_PING_INTERVAL_SECONDS=15
LIVE_LOCATION_STALE_SECONDS=45
ONLINE_WINDOW_SECONDS=30

# GPS accuracy (mobile should send accuracy in meters with each ping)
GPS_GOOD_ACCURACY_METERS=25
GPS_MAX_ACCEPTABLE_ACCURACY_METERS=100
GPS_REJECT_ACCURACY_METERS=200
GPS_LIVE_DEFAULT_BUFFER_METERS=50
GPS_REQUIRE_ACCURACY=true

# =============================================================================
# Google Maps (admin live map page)
# =============================================================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
